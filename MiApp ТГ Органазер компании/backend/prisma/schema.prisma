generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  telegramId     String?   @unique
  name           String
  email          String    @unique
  emailVerified  Boolean   @default(false)
  // Связанные токены подтверждения email
  emailVerificationTokens EmailVerificationToken[]

  companies      Company[] @relation("CompanyOwner")
  memberships    CompanyMember[]
  calendarMemberships CalendarMember[]
  eventsCreated  Event[]  @relation("EventCreatedBy")
  comments       EventComment[]
  notifications  Notification[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime

  user       User     @relation(fields: [userId], references: [id])

  createdAt  DateTime @default(now())
}

model Company {
  id           String          @id @default(cuid())
  name         String
  timezone     String
  ownerUserId  String

  owner        User            @relation("CompanyOwner", fields: [ownerUserId], references: [id])
  members      CompanyMember[]
  calendars    Calendar[]
  invites      Invite[]
  events       Event[]

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model CompanyMember {
  id         String        @id @default(cuid())
  companyId  String
  userId     String
  role       CompanyRole

  company    Company       @relation(fields: [companyId], references: [id])
  user       User          @relation(fields: [userId], references: [id])

  createdAt  DateTime      @default(now())

  @@unique([companyId, userId])
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Invite {
  id         String      @id @default(cuid())
  companyId  String
  email      String
  role       CompanyRole
  token      String      @unique
  expiresAt  DateTime

  company    Company     @relation(fields: [companyId], references: [id])

  createdAt  DateTime    @default(now())
}

model Calendar {
  id           String            @id @default(cuid())
  companyId    String
  name         String
  type         String
  ownerUserId  String

  company      Company           @relation(fields: [companyId], references: [id])
  owner        User              @relation(fields: [ownerUserId], references: [id])
  members      CalendarMember[]
  events       Event[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model CalendarMember {
  id           String            @id @default(cuid())
  calendarId   String
  userId       String
  permission   CalendarPermission

  calendar     Calendar          @relation(fields: [calendarId], references: [id])
  user         User              @relation(fields: [userId], references: [id])

  createdAt    DateTime          @default(now())

  @@unique([calendarId, userId])
}

enum CalendarPermission {
  VIEW
  EDIT
  MANAGE
}

model Event {
  id           String          @id @default(cuid())
  companyId    String
  calendarId   String
  title        String
  description  String?
  startAt      DateTime
  endAt        DateTime
  allDay       Boolean         @default(false)
  status       EventStatus     @default(PENDING)
  priority     EventPriority   @default(NORMAL)
  createdById  String

  company      Company         @relation(fields: [companyId], references: [id])
  calendar     Calendar        @relation(fields: [calendarId], references: [id])
  createdBy    User            @relation("EventCreatedBy", fields: [createdById], references: [id])
  comments     EventComment[]
  notifications Notification[]

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

enum EventStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

enum EventPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model EventComment {
  id         String    @id @default(cuid())
  eventId    String
  userId     String
  text       String
  createdAt  DateTime  @default(now())

  event      Event     @relation(fields: [eventId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
}

model Notification {
  id           String         @id @default(cuid())
  userId       String
  eventId      String
  type         String
  scheduledAt  DateTime
  sentAt       DateTime?

  user         User           @relation(fields: [userId], references: [id])
  event        Event          @relation(fields: [eventId], references: [id])

  createdAt    DateTime       @default(now())
}

